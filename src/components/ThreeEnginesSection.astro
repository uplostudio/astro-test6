<script is:inline>
(function(){
var el = document.currentScript.previousElementSibling;
function __init__() {
(function _w(n){var c=n.firstChild,x;while(c){x=c.nextSibling;if(c.nodeType===3){if(!c.textContent.trim())n.removeChild(c)}else if(c.nodeType===1)_w(c);c=x}})(el);
var root = el;
var balloons = root.querySelector('[data-el="balloons"]');
var textEls = root.querySelectorAll('[data-el="parallax-text"]');

gsap.registerPlugin(ScrollTrigger);

gsap.to(balloons, {
  y: -200,
  ease: 'none',
  scrollTrigger: {
    trigger: root,
    start: 'top bottom',
    end: 'bottom top',
    scrub: true
  }
});

// "One", "platform", "three", "engines" — engines stays put
var textSpeeds = [100, 150, 80, 0];
textEls.forEach(function (item, i) {
  if (textSpeeds[i] === 0) return;
  gsap.to(item, {
    y: textSpeeds[i],
    ease: 'none',
    scrollTrigger: {
      trigger: root,
      start: 'top bottom',
      end: 'bottom top',
      scrub: true
    }
  });
});

}
if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', __init__); } else { __init__(); }
})();
</script>
