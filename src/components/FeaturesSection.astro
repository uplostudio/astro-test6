<script is:inline>
(function(){
var el = document.currentScript.previousElementSibling;
function __init__() {
(function _w(n){var c=n.firstChild,x;while(c){x=c.nextSibling;if(c.nodeType===3){if(!c.textContent.trim())n.removeChild(c)}else if(c.nodeType===1)_w(c);c=x}})(el);
gsap.registerPlugin(ScrollTrigger);

const balloon = el.querySelector('[data-el="balloon"]');

if (balloon) {
  // Only clip at the bottom so balloon can overflow top but hides behind next section
  el.style.overflow = "visible";
  el.style.clipPath = "inset(-100% -100% 0 -100%)";

  // Set initial state to match scroll animation start
  gsap.set(balloon, { scale: 2.2, x: "0%", y: 0, rotation: 0, filter: "blur(0px)" });

  // Ambient floating — applied to the inner video so it doesn't conflict
  const balloonVideo = balloon.querySelector('[data-el="balloon-video"]');
  if (balloonVideo) {
    gsap.to(balloonVideo, {
      y: -10,
      rotation: 4,
      duration: 2.8,
      ease: "sine.inOut",
      yoyo: true,
      repeat: -1,
    });
    gsap.to(balloonVideo, {
      x: 6,
      duration: 3.6,
      ease: "sine.inOut",
      yoyo: true,
      repeat: -1,
    });
  }

  // Scroll-linked float down — scrub with lag for floaty balloon feel
  gsap.fromTo(balloon,
    {
      y: 0,
      x: "0%",
      scale: 2.2,
      rotation: 0,
      filter: "blur(0px)",
    },
    {
      y: () => el.offsetHeight + 50,
      x: "-50%",
      scale: 1,
      rotation: -8,
      filter: "blur(8px)",
      ease: "power1.inOut",
      immediateRender: false,
      scrollTrigger: {
        trigger: el,
        start: "top 50%",
        end: "bottom 30%",
        scrub: 2.5,
      },
    }
  );
}

}
if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', __init__); } else { __init__(); }
})();
</script>
