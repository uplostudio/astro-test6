[data-el='faq-item'].is-active .c_accordionssection_b9or9 { max-height: 37.5rem; opacity: 1; }

[data-el='faq-item'].is-active .c_accordionssection_stroke { background-color: var(--transparent); }

[data-el="faq-item"].is-active .c_accordionssection_dottopleft { background: var(--ploy-background-primary); }

[data-el="faq-item"].is-active .c_accordionssection_dotbottomleft { background: var(--ploy-background-primary); }

[data-el="faq-item"].is-active .c_accordionssection_dottopright { background: var(--ploy-background-primary); }

