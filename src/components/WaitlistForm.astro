<script is:inline>
(function(){
var el = document.currentScript.previousElementSibling;
function __init__() {
(function _w(n){var c=n.firstChild,x;while(c){x=c.nextSibling;if(c.nodeType===3){if(!c.textContent.trim())n.removeChild(c)}else if(c.nodeType===1)_w(c);c=x}})(el);
// Keyboard highlight style for dropdown options
const highlightStyle = document.createElement('style');
highlightStyle.textContent = '[data-el="dropdown-option"].is-highlighted { background: rgba(33, 33, 33, 0.04); } [data-el="multiselect-option"].is-highlighted { background: rgba(33, 33, 33, 0.04); }';
el.appendChild(highlightStyle);

// Floating label behavior for text inputs
const inputGroups = el.querySelectorAll('[data-el="input-group"]');

inputGroups.forEach(group => {
  const input = group.querySelector('[data-el="input"]');
  const label = group.querySelector('[data-el="label"]');
  if (!input || !label) return;

  function labelUp() {
    label.style.fontSize = '14px';
    label.style.fontWeight = '400';
    label.style.top = '-4px';
    label.style.color = 'rgba(33, 33, 33, 0.5)';
  }

  function labelDown() {
    label.style.fontSize = '';
    label.style.fontWeight = '';
    label.style.top = '';
    label.style.color = '';
  }

  function clearError() {
    group.style.borderBottomColor = '';
    label.style.color = '';
    if (input.value.trim()) {
      label.style.color = 'rgba(33, 33, 33, 0.5)';
    }
  }

  input.addEventListener('focus', () => {
    clearError();
    labelUp();
  });

  input.addEventListener('blur', () => {
    if (!input.value.trim()) {
      labelDown();
    }
  });

  // Numbers-only filter for company size
  if (input.name === 'companySize') {
    input.addEventListener('input', () => {
      input.value = input.value.replace(/[^0-9]/g, '');
      clearError();
      if (input.value.trim()) {
        labelUp();
      }
    });
  } else {
    input.addEventListener('input', () => {
      clearError();
      if (input.value.trim()) {
        labelUp();
      }
    });
  }
});

// Dropdown behavior (single-select)
const dropdownGroups = el.querySelectorAll('[data-el="dropdown-group"]');

dropdownGroups.forEach(group => {
  const trigger = group.querySelector('[data-el="dropdown-trigger"]');
  const valueEl = group.querySelector('[data-el="dropdown-value"]');
  const menu = group.querySelector('[data-el="dropdown-menu"]');
  const options = group.querySelectorAll('[data-el="dropdown-option"]');
  const hiddenInput = group.querySelector('[data-el="dropdown-hidden-input"]');
  const label = group.querySelector('[data-el="label"]');
  const chevron = group.querySelector('[data-el="chevron"]');

  if (!trigger || !menu) return;

  trigger.setAttribute('tabindex', '0');
  trigger.setAttribute('role', 'combobox');
  trigger.setAttribute('aria-expanded', 'false');
  trigger.setAttribute('aria-haspopup', 'listbox');
  if (label) trigger.setAttribute('aria-label', label.textContent);
  menu.setAttribute('role', 'listbox');
  options.forEach((option, i) => {
    option.setAttribute('role', 'option');
    option.setAttribute('tabindex', '-1');
    option.id = group.getAttribute('data-el') + '-option-' + hiddenInput.name + '-' + i;
  });

  let activeIndex = -1;

  function setLabelUp() {
    if (!label) return;
    label.style.fontSize = '14px';
    label.style.fontWeight = '400';
    label.style.top = '-4px';
    label.style.color = 'rgba(33, 33, 33, 0.5)';
  }

  function setLabelDown() {
    if (!label) return;
    label.style.fontSize = '';
    label.style.fontWeight = '';
    label.style.top = '';
    label.style.color = '';
  }

  function closeOtherDropdowns() {
    dropdownGroups.forEach(other => {
      if (other !== group) {
        other.classList.remove('is-open');
        const otherTrigger = other.querySelector('[data-el="dropdown-trigger"]');
        const otherChevron = other.querySelector('[data-el="chevron"]');
        if (otherTrigger) otherTrigger.setAttribute('aria-expanded', 'false');
        if (otherChevron) otherChevron.style.transform = '';
      }
    });
  }

  function closeAllMultiselects() {
    el.querySelectorAll('[data-el="multiselect-group"]').forEach(ms => {
      ms.classList.remove('is-open');
      const msTrigger = ms.querySelector('[data-el="multiselect-trigger"]');
      const msChevron = ms.querySelector('[data-el="chevron"]');
      if (msTrigger) msTrigger.setAttribute('aria-expanded', 'false');
      if (msChevron) msChevron.style.transform = '';
    });
  }

  function openDropdown() {
    closeOtherDropdowns();
    closeAllMultiselects();
    group.classList.add('is-open');
    trigger.setAttribute('aria-expanded', 'true');
    if (chevron) chevron.style.transform = 'rotate(180deg)';
    setLabelUp();
    activeIndex = -1;
  }

  function closeDropdown(restoreLabel) {
    group.classList.remove('is-open');
    trigger.setAttribute('aria-expanded', 'false');
    if (chevron) chevron.style.transform = '';
    activeIndex = -1;
    options.forEach(o => o.classList.remove('is-highlighted'));
    if (restoreLabel && (!hiddenInput || !hiddenInput.value)) {
      setLabelDown();
    }
  }

  let justSelected = false;

  function selectOption(option) {
    const value = option.getAttribute('data-value');
    if (valueEl) valueEl.textContent = option.textContent;
    if (hiddenInput) hiddenInput.value = value;
    group.classList.add('has-value');
    group.style.borderBottomColor = '';
    setLabelUp();
    closeDropdown(false);
    justSelected = true;
    trigger.focus();
  }

  function highlightOption(index) {
    options.forEach(o => o.classList.remove('is-highlighted'));
    if (index >= 0 && index < options.length) {
      activeIndex = index;
      options[index].classList.add('is-highlighted');
      options[index].scrollIntoView({ block: 'nearest' });
      trigger.setAttribute('aria-activedescendant', options[index].id);
    }
  }

  let mouseDown = false;
  trigger.addEventListener('mousedown', () => { mouseDown = true; });

  trigger.addEventListener('click', (e) => {
    e.stopPropagation();
    mouseDown = false;
    if (group.classList.contains('is-open')) {
      closeDropdown(true);
    } else {
      openDropdown();
    }
  });

  trigger.addEventListener('focus', () => {
    if (!mouseDown && !justSelected && !group.classList.contains('is-open')) {
      openDropdown();
    }
    mouseDown = false;
    justSelected = false;
  });

  trigger.addEventListener('keydown', (e) => {
    switch (e.key) {
      case 'Enter':
      case ' ':
        e.preventDefault();
        if (group.classList.contains('is-open')) {
          if (activeIndex >= 0) selectOption(options[activeIndex]);
          else closeDropdown(true);
        } else {
          openDropdown();
        }
        break;
      case 'ArrowDown':
        e.preventDefault();
        if (!group.classList.contains('is-open')) openDropdown();
        highlightOption(Math.min(activeIndex + 1, options.length - 1));
        break;
      case 'ArrowUp':
        e.preventDefault();
        if (!group.classList.contains('is-open')) openDropdown();
        highlightOption(Math.max(activeIndex - 1, 0));
        break;
      case 'Escape':
        e.preventDefault();
        closeDropdown(true);
        trigger.focus();
        break;
      case 'Tab':
        closeDropdown(true);
        break;
    }
  });

  options.forEach(option => {
    option.addEventListener('click', (e) => {
      e.stopPropagation();
      selectOption(option);
    });
  });

  document.addEventListener('click', (e) => {
    if (!group.contains(e.target)) {
      closeDropdown(true);
    }
  });
});

// Multiselect behavior
const multiselectGroups = el.querySelectorAll('[data-el="multiselect-group"]');

multiselectGroups.forEach(group => {
  const trigger = group.querySelector('[data-el="multiselect-trigger"]');
  const valueEl = group.querySelector('[data-el="multiselect-value"]');
  const menu = group.querySelector('[data-el="multiselect-menu"]');
  const options = group.querySelectorAll('[data-el="multiselect-option"]');
  const hiddenInput = group.querySelector('[data-el="multiselect-hidden-input"]');
  const label = group.querySelector('[data-el="label"]');
  const chevron = group.querySelector('[data-el="chevron"]');

  if (!trigger || !menu) return;

  const selectedValues = new Set();

  trigger.setAttribute('tabindex', '0');
  trigger.setAttribute('role', 'combobox');
  trigger.setAttribute('aria-expanded', 'false');
  trigger.setAttribute('aria-haspopup', 'listbox');
  if (label) trigger.setAttribute('aria-label', label.textContent);
  menu.setAttribute('role', 'listbox');
  options.forEach((option, i) => {
    option.setAttribute('role', 'option');
    option.setAttribute('tabindex', '-1');
    option.id = 'multiselect-option-' + (hiddenInput ? hiddenInput.name : 'ms') + '-' + i;
  });

  let activeIndex = -1;

  function setLabelUp() {
    if (!label) return;
    label.style.fontSize = '14px';
    label.style.fontWeight = '400';
    label.style.top = '-4px';
    label.style.color = 'rgba(33, 33, 33, 0.5)';
  }

  function setLabelDown() {
    if (!label) return;
    label.style.fontSize = '';
    label.style.fontWeight = '';
    label.style.top = '';
    label.style.color = '';
  }

  function closeOtherPanels() {
    dropdownGroups.forEach(dd => {
      dd.classList.remove('is-open');
      const ddTrigger = dd.querySelector('[data-el="dropdown-trigger"]');
      const ddChevron = dd.querySelector('[data-el="chevron"]');
      if (ddTrigger) ddTrigger.setAttribute('aria-expanded', 'false');
      if (ddChevron) ddChevron.style.transform = '';
    });
    multiselectGroups.forEach(other => {
      if (other !== group) {
        other.classList.remove('is-open');
        const otherTrigger = other.querySelector('[data-el="multiselect-trigger"]');
        const otherChevron = other.querySelector('[data-el="chevron"]');
        if (otherTrigger) otherTrigger.setAttribute('aria-expanded', 'false');
        if (otherChevron) otherChevron.style.transform = '';
      }
    });
  }

  function updateDisplay() {
    const values = Array.from(selectedValues);
    if (valueEl) valueEl.textContent = values.join(', ');
    if (hiddenInput) hiddenInput.value = values.join(', ');
    if (values.length > 0) {
      group.classList.add('has-value');
      setLabelUp();
    } else {
      group.classList.remove('has-value');
    }
    group.style.borderBottomColor = '';
  }

  function openMultiselect() {
    closeOtherPanels();
    group.classList.add('is-open');
    trigger.setAttribute('aria-expanded', 'true');
    if (chevron) chevron.style.transform = 'rotate(180deg)';
    setLabelUp();
    activeIndex = -1;
  }

  function closeMultiselect(restoreLabel) {
    group.classList.remove('is-open');
    trigger.setAttribute('aria-expanded', 'false');
    if (chevron) chevron.style.transform = '';
    activeIndex = -1;
    options.forEach(o => o.classList.remove('is-highlighted'));
    if (restoreLabel && selectedValues.size === 0) {
      setLabelDown();
    }
  }

  function toggleOption(option) {
    const value = option.getAttribute('data-value');
    if (selectedValues.has(value)) {
      selectedValues.delete(value);
      option.classList.remove('is-checked');
    } else {
      selectedValues.add(value);
      option.classList.add('is-checked');
    }
    updateDisplay();
  }

  function highlightOption(index) {
    options.forEach(o => o.classList.remove('is-highlighted'));
    if (index >= 0 && index < options.length) {
      activeIndex = index;
      options[index].classList.add('is-highlighted');
      options[index].scrollIntoView({ block: 'nearest' });
      trigger.setAttribute('aria-activedescendant', options[index].id);
    }
  }

  let mouseDown = false;
  trigger.addEventListener('mousedown', () => { mouseDown = true; });

  trigger.addEventListener('click', (e) => {
    e.stopPropagation();
    mouseDown = false;
    if (group.classList.contains('is-open')) {
      closeMultiselect(true);
    } else {
      openMultiselect();
    }
  });

  trigger.addEventListener('focus', () => {
    if (!mouseDown && !group.classList.contains('is-open')) {
      openMultiselect();
    }
    mouseDown = false;
  });

  trigger.addEventListener('keydown', (e) => {
    switch (e.key) {
      case 'Enter':
      case ' ':
        e.preventDefault();
        if (group.classList.contains('is-open')) {
          if (activeIndex >= 0) toggleOption(options[activeIndex]);
          else closeMultiselect(true);
        } else {
          openMultiselect();
        }
        break;
      case 'ArrowDown':
        e.preventDefault();
        if (!group.classList.contains('is-open')) openMultiselect();
        highlightOption(Math.min(activeIndex + 1, options.length - 1));
        break;
      case 'ArrowUp':
        e.preventDefault();
        if (!group.classList.contains('is-open')) openMultiselect();
        highlightOption(Math.max(activeIndex - 1, 0));
        break;
      case 'Escape':
        e.preventDefault();
        closeMultiselect(true);
        trigger.focus();
        break;
      case 'Tab':
        closeMultiselect(true);
        break;
    }
  });

  // Option click toggles checkbox, doesn't close dropdown
  options.forEach(option => {
    option.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleOption(option);
    });
  });

  document.addEventListener('click', (e) => {
    if (!group.contains(e.target)) {
      closeMultiselect(true);
    }
  });
});

// Validation + Form submit
const ERROR_COLOR = 'rgb(220, 38, 38)';

function markError(group, label) {
  group.style.borderBottomColor = ERROR_COLOR;
  if (label) label.style.color = ERROR_COLOR;
}

function validateForm() {
  let valid = true;

  inputGroups.forEach(group => {
    const input = group.querySelector('[data-el="input"]');
    const label = group.querySelector('[data-el="label"]');
    if (input && !input.value.trim()) {
      markError(group, label);
      valid = false;
    }
  });

  dropdownGroups.forEach(group => {
    const hiddenInput = group.querySelector('[data-el="dropdown-hidden-input"]');
    const label = group.querySelector('[data-el="label"]');
    if (hiddenInput && !hiddenInput.value) {
      markError(group, label);
      valid = false;
    }
  });

  multiselectGroups.forEach(group => {
    const hiddenInput = group.querySelector('[data-el="multiselect-hidden-input"]');
    const label = group.querySelector('[data-el="label"]');
    if (hiddenInput && !hiddenInput.value) {
      markError(group, label);
      valid = false;
    }
  });

  return valid;
}

const form = el.querySelector('[data-el="waitlist-form"]') || el;
const submitBtn = el.querySelector('[data-el="submit-btn"]');
const successMessage = el.querySelector('[data-el="success-message"]');

function handleSubmit(e) {
  e.preventDefault();
  if (!validateForm()) return;

  const formContent = form.tagName === 'FORM'
    ? form.querySelector(':scope > div:first-child')
    : el.querySelector(':scope > div:first-child');

  // Fade out form content + button
  const fadeTargets = [formContent, submitBtn].filter(Boolean);
  fadeTargets.forEach(target => {
    target.style.transition = 'opacity 0.3s ease';
    target.style.opacity = '0';
  });

  setTimeout(() => {
    fadeTargets.forEach(target => target.style.display = 'none');

    if (successMessage) {
      successMessage.style.display = 'flex';
      successMessage.style.opacity = '0';
      successMessage.style.transform = 'translateY(12px)';
      successMessage.style.transition = 'opacity 0.4s ease, transform 0.4s ease';

      requestAnimationFrame(() => {
        successMessage.style.opacity = '1';
        successMessage.style.transform = 'translateY(0)';
      });
    }

    // Trigger splash video
    document.dispatchEvent(new CustomEvent('waitlist-success'));
  }, 300);
}

if (form.tagName === 'FORM') {
  form.addEventListener('submit', handleSubmit);
} else if (submitBtn) {
  submitBtn.addEventListener('click', handleSubmit);
}

// Ensure submit button is focusable
if (submitBtn) {
  submitBtn.setAttribute('tabindex', '0');
}

// Allow Enter key to submit from any input/dropdown in the form
el.addEventListener('keydown', (e) => {
  if (e.key === 'Enter' && e.target.closest('[data-el="dropdown-trigger"]') === null) {
    e.preventDefault();
    if (submitBtn) submitBtn.click();
  }
});

// GSAP hover animation for submit button
if (submitBtn) {
  const btnOriginalText = submitBtn.textContent.trim();
  submitBtn.textContent = '';

  // Background element for scale effect
  const btnBg = document.createElement('span');
  btnBg.style.cssText = 'position:absolute;inset:0;border-radius:inherit;background:inherit;z-index:0;transition:scale .75s cubic-bezier(.32,.72,0,1);pointer-events:none;';
  submitBtn.style.position = 'absolute';
  submitBtn.style.overflow = 'hidden';
  submitBtn.appendChild(btnBg);

  // Text wrapper
  const btnTextWrap = document.createElement('span');
  btnTextWrap.style.cssText = 'position:relative;z-index:1;display:flex;gap:0;align-items:center;';
  submitBtn.appendChild(btnTextWrap);

  const btnChars = [];
  for (let i = 0; i < btnOriginalText.length; i++) {
    const span = document.createElement('span');
    span.textContent = btnOriginalText[i] === ' ' ? '\u00A0' : btnOriginalText[i];
    span.style.display = 'inline-block';
    btnTextWrap.appendChild(span);
    btnChars.push(span);
  }

  const btnOriginalColor = getComputedStyle(submitBtn).color;

  // Active press
  submitBtn.style.transition = 'transform .45s linear(0,0.5737 7.6%,0.8382 11.87%,0.9463 14.19%,1.0292 16.54%,1.0886 18.97%,1.1258 21.53%,1.137 22.97%,1.1424 24.48%,1.1423 26.1%,1.1366 27.86%,1.1165 31.01%,1.0507 38.62%,1.0219 42.57%,0.9995 46.99%,0.9872 51.63%,0.9842 58.77%,1.0011 81.26%,1)';
  submitBtn.style.webkitTapHighlightColor = 'transparent';

  submitBtn.addEventListener('pointerdown', () => {
    submitBtn.style.transform = 'translateX(-50%) scaleX(0.955) scaleY(0.954)';
  });
  submitBtn.addEventListener('pointerup', () => {
    submitBtn.style.transform = 'translateX(-50%)';
  });

  // GSAP hover
  gsap.set(btnChars, { transformOrigin: 'bottom left' });

  const btnHoverColors = ['#FFB8FC', '#C3DBFF', '#FFFA64', '#D1F48C'];
  let btnLastColor = null;
  let btnHoverTl = null;

  function btnPickColor() {
    const available = btnHoverColors.filter(c => c !== btnLastColor);
    const picked = available[Math.floor(Math.random() * available.length)];
    btnLastColor = picked;
    return picked;
  }

  function btnBuildTimeline(color) {
    if (btnHoverTl) btnHoverTl.kill();

    btnHoverTl = gsap.timeline({
      onComplete() {
        btnHoverTl.progress(0).pause();
        gsap.set(btnChars, { color: btnOriginalColor, scaleY: 1, rotate: 0 });
      }
    });

    btnHoverTl
      .to(btnChars, {
        keyframes: {
          '0%': { scaleY: 1, rotate: 0 },
          '20%': { scaleY: 0.25, rotate: 20, ease: 'power2.in' },
          '100%': { scaleY: 1, rotate: 0, ease: 'elastic.out(1,0.4)' },
        },
        duration: 0.7,
        stagger: 0.017,
      })
      .to(btnChars, {
        keyframes: {
          '0%': { color: color },
          '40%': { color: color },
          '100%': { color: btnOriginalColor },
        },
        duration: 0.7,
        stagger: 0.017,
      }, '<');
  }

  submitBtn.style.outline = 'none';

  function btnOnHover() {
    btnBuildTimeline(btnPickColor());
    btnHoverTl.play();
    btnBg.style.scale = '1.035 1.065';
    gsap.to(submitBtn, { scaleX: 1.05, scaleY: 1.08, duration: 0.5, ease: 'elastic.out(1,0.5)' });
  }

  function btnOnHoverEnd() {
    btnBg.style.scale = '';
    submitBtn.style.transform = 'translateX(-50%)';
    gsap.to(submitBtn, { scaleX: 1, scaleY: 1, duration: 0.4, ease: 'power2.out' });
  }

  submitBtn.addEventListener('pointerenter', btnOnHover);
  submitBtn.addEventListener('focus', () => {
    btnOnHover();
    submitBtn.style.boxShadow = '0 0 0 3px rgba(255, 255, 255, 0.6), 0 0 0 5px rgba(33, 33, 33, 0.3)';
  });
  submitBtn.addEventListener('pointerleave', btnOnHoverEnd);
  submitBtn.addEventListener('blur', () => {
    btnOnHoverEnd();
    submitBtn.style.boxShadow = '';
  });
}

}
if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', __init__); } else { __init__(); }
})();
</script>
