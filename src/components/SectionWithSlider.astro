---
import SliderItemCard from './SliderItemCard.astro';

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---
<div class:list={["pl-[var(--c-p)] pr-[var(--c-p)] pb-[24px] flex justify-center items-center h-auto relative max-[540px]:h-min max-[1024px]:pb-[22px] max-[540px]:pb-[20px]", className]} src="/images/sectionwithslider%20image.webp">
  <div class="rounded-[20px] bg-[var(--ploy-brand-blue)] p-[76px_96px] relative overflow-hidden h-full w-full max-[1024px]:p-[48px] max-[540px]:p-[32px] max-[540px]:h-min">
    <div class="max-w-[var(--c-mw)] w-full ml-auto mr-auto">
      <div class="flex flex-col justify-start gap-[24px] z-[2] max-[1024px]:gap-[21px] max-[540px]:gap-[19px]">
        <div>
          <h2 class="font-[family-name:var(--font-heading)] text-[length:var(--font-size-7xl)] font-[number:var(--font-heading-weight)] leading-[86%] uppercase text-[color:var(--ploy-text-primary)] mb-[24px] max-[540px]:text-[length:var(--font-size-4xl)] max-[1024px]:text-[length:var(--font-size_7xl)] max-[1024px]:mb-[22px] max-[540px]:mb-[20px]" data-el="slider-heading">
            <span class="flex">
              expert strategies,
            </span>
            <span>
              deployed
            </span>
            <span class="h-[0.86em] w-[0px] inline-block relative overflow-hidden align-[middle]" data-el="blue-balloon-container">
              <span class="block absolute top-[50%] left-[50%] [transform:translate(-50%,_-50%)_scale(0)] w-[100px] h-[100px]" data-el="blue-balloon-sizer">
                <div class="oem w-full h-full">
                  <Fragment set:html={`<video autoplay loop muted playsinline style='width:100%;height:100%;object-fit:contain;'><source src='https://ploy.sfo3.cdn.digitaloceanspaces.com/ploy-final/blue-balloon-safari.mov' type='video/mp4; codecs=hvc1'><source src='https://ploy.sfo3.cdn.digitaloceanspaces.com/ploy-final/blue-balloon.webm' type='video/webm'></video>`} />
                </div>
              </span>
            </span>
            <span>
              for you.
            </span>
          </h2>
        </div>
        <div class="flex flex-row justify-end">
          <div class="max-w-[50%] max-[540px]:max-w-full">
            <p class="max-w-[588px] w-full text-[length:var(--font-size-base)] leading-[var(--font-body-line-height)] tracking-[var(--font-body-letter-spacing)] text-[color:var(--ploy-text-primary)] opacity-[0.64]">
              PloyBooks are pre-built growth strategies executed by specialized agents. Run them on a schedule, trigger them from an event, or let Ploy decide.
            </p>
            <div class="flex items-center gap-[12px] pb-[24px] pt-[24px] w-min max-[1024px]:pb-[22px] max-[540px]:pb-[20px] max-[1024px]:pt-[22px] max-[540px]:pt-[20px]">
              <div class="c_sectionwithslider_buttonprev flex justify-center items-center bg-[var(--ploy-button-primary-background)] rounded-full w-[36px] h-[36px] cursor-pointer [transition:background_0.2s_ease,_transform_0.2s_ease,_opacity_0.2s_ease]" data-el="prev">
                <div class="oem w-[16px] h-[16px]">
                  <Fragment set:html={`<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10 12L6 8L10 4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`} />
                </div>
              </div>
              <div class="c_sectionwithslider_buttonnext flex justify-center items-center bg-[var(--ploy-button-primary-background)] rounded-full w-[36px] h-[36px] cursor-pointer [transition:background_0.2s_ease,_transform_0.2s_ease]" data-el="next">
                <div class="oem w-[16px] h-[16px]">
                  <Fragment set:html={`<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 4L10 8L6 12" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`} />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="z-[2]">
        <div class="flex flex-col items-center">
          <div class="flex gap-[24px] w-full pl-[0px] overflow-visible items-stretch max-[1024px]:gap-[8px] max-[540px]:gap-[19px]" data-el="swiper">
            <SliderItemCard Title="SEO Audit Blueprint" text2="Audits your site across technical SEO, content, keywords, backlinks, competitors, and AI search visibility." />
            <SliderItemCard Title="Competitor Intel
" text2="Monitors competitor sites, pricing changes, positioning shifts, and new pages to uncover missed opportunities.
" />
            <SliderItemCard Title="Conversion Machine
" text2="Runs continuous A/B tests on pages, headlines, and CTAs to scale what converts and cut what doesn’t.
" />
            <SliderItemCard Title="Content Engine" text2="Researches high-intent topics, creates comparison pages, and optimizes content for search on autopilot.
" />
            <SliderItemCard Title="SEO Audit Blueprint" text2="Audits your site across technical SEO, content, keywords, backlinks, competitors, and AI search visibility." />
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style is:global>
.c_sectionwithslider_buttonprev:hover { background: var(--ploy-surface-dark); transform: scale(1.08); }
.c_sectionwithslider_buttonprev:active { transform: scale(0.95); }

.c_sectionwithslider_buttonnext:hover { background: var(--ploy-surface-dark); transform: scale(1.08); }
.c_sectionwithslider_buttonnext:active { transform: scale(0.95); }
</style>

<script is:inline>
(function(){
var el = document.currentScript.previousElementSibling;
function __init__() {
(function _w(n){var c=n.firstChild,x;while(c){x=c.nextSibling;if(c.nodeType===3){if(!c.textContent.trim())n.removeChild(c)}else if(c.nodeType===1)_w(c);c=x}})(el);
const swiperContainer = el.querySelector('[data-el="swiper"]');
const prevBtn = el.querySelector('[data-el="prev"]');
const nextBtn = el.querySelector('[data-el="next"]');

if (swiperContainer && typeof Swiper !== 'undefined') {
  swiperContainer.classList.add('swiper');

  const wrapper = document.createElement('div');
  wrapper.classList.add('swiper-wrapper');

  while (swiperContainer.firstChild) {
    const slideEl = document.createElement('div');
    slideEl.classList.add('swiper-slide');
    slideEl.style.width = 'auto';
    slideEl.style.height = 'auto';
    slideEl.appendChild(swiperContainer.firstChild);
    wrapper.appendChild(slideEl);
  }

  swiperContainer.appendChild(wrapper);

  const setEnabled = (btn, enabled) => {
    if (!btn) return;
    const svg = btn.querySelector('svg path');
    if (enabled) {
      btn.style.background = 'rgb(33, 33, 33)';
      btn.style.border = 'none';
      btn.style.cursor = 'pointer';
      btn.style.pointerEvents = 'auto';
      if (svg) svg.setAttribute('stroke', 'white');
    } else {
      btn.style.background = 'transparent';
      btn.style.border = '1px solid rgba(33, 33, 33, 0.12)';
      btn.style.cursor = 'default';
      btn.style.pointerEvents = 'none';
      if (svg) svg.setAttribute('stroke', '#212121');
    }
  };

  const updateButtons = (swiper) => {
    setEnabled(prevBtn, !swiper.isBeginning);
    setEnabled(nextBtn, !swiper.isEnd);
  };

  swiperContainer.style.cursor = 'grab';

  const swiper = new Swiper(swiperContainer, {
    slidesPerView: 'auto',
    spaceBetween: 24,
    autoHeight: false,
    grabCursor: true,
    mousewheel: {
      forceToAxis: true
    },
    keyboard: {
      enabled: true,
      onlyInViewport: true
    },
    freeMode: {
      enabled: true,
      sticky: true
    },
    navigation: {
      prevEl: prevBtn,
      nextEl: nextBtn
    },
    on: {
      init: updateButtons,
      slideChange: updateButtons,
      reachBeginning: updateButtons,
      reachEnd: updateButtons,
      fromEdge: updateButtons,
    }
  });

  // Force equal height on all slides
  wrapper.style.alignItems = 'stretch';
}

// Blue balloon — inflate on scroll, push text apart
var heading = el.querySelector('[data-el="slider-heading"]');
var balloonContainer = el.querySelector('[data-el="blue-balloon-container"]');
var balloonSizer = el.querySelector('[data-el="blue-balloon-sizer"]');

if (heading && balloonContainer && balloonSizer) {
  var targetWidth = 100;

  function inflateBlueBalloon() {
    balloonContainer.style.overflow = 'visible';
    heading.style.overflow = 'visible';

    if (typeof gsap !== 'undefined') {
      var tl = gsap.timeline();
      tl.to(balloonContainer, {
        width: targetWidth,
        duration: 0.8,
        ease: 'power2.out'
      }, 0);
      tl.fromTo(balloonSizer,
        { scale: 0, opacity: 0 },
        { scale: 1, opacity: 1, duration: 0.8, ease: 'back.out(1.7)' },
        0.1
      );
    } else {
      balloonContainer.style.width = targetWidth + 'px';
      balloonSizer.style.transform = 'translate(-50%, -50%) scale(1)';
      balloonSizer.style.opacity = '1';
    }
  }

  if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);
    ScrollTrigger.create({
      trigger: heading,
      start: 'top 80%',
      once: true,
      onEnter: inflateBlueBalloon
    });
  } else {
    var balloonObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          inflateBlueBalloon();
          balloonObs.unobserve(e.target);
        }
      });
    }, { threshold: 0.2 });
    balloonObs.observe(heading);
  }
}

}
if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', __init__); } else { __init__(); }
})();
</script>
