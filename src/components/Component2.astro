---
import Copyright from './Copyright.astro';

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---
<footer class:list={["pr-[var(--c-p)] pl-[var(--c-p)] pb-[var(--c-p)]", className]}>
  <div class="w-full flex flex-col items-center gap-[44px] p-[48px_32px] bg-[var(--ploy-button-primary-background)] rounded-[20px_20px_20px_20px] overflow-hidden relative max-[1024px]:rounded-[20px_20px_0_0] max-[1024px]:gap-[32px] max-[540px]:gap-[24px] max-[540px]:rounded-[20px_20px_0_0] max-[540px]:p-[32px_20px] max-[1024px]:p-[40px_28px]">
    <div class="oem [transform:scale(1.3)] object-contain w-full overflow-visible mt-[-10%] mb-[-10%] pointer-events-none">
      <Fragment set:html={`<video autoplay muted playsinline data-el='footer-video' style='width:100%;object-fit:cover;pointer-events:none;'><source src='https://ploy.sfo3.cdn.digitaloceanspaces.com/ploy-final/footer3-transparent-safari.mov' type='video/mp4; codecs=hvc1'><source src='https://ploy.sfo3.cdn.digitaloceanspaces.com/ploy-final/footer3-transparent.webm' type='video/webm'></video>`} />
    </div>
    <div class="flex flex-col items-start gap-[76px] w-full max-w-[var(--c-mw)] max-[1024px]:w-full max-[1024px]:gap-[55px] max-[540px]:gap-[40px]">
      <div class="flex justify-between items-start w-full flex-row max-[540px]:flex-col max-[540px]:gap-[32px]">
        <p class="max-w-[384px] w-full text-[length:var(--font-size-base)] leading-[var(--font-body-line-height)] tracking-[var(--font-body-letter-spacing)] text-[color:var(--ploy-background-secondary)] opacity-[0.64] max-[540px]:max-w-full">
          Ploy builds, tests, and optimizes your website. Automatically.
        </p>
        <div>
          <a href="mailto:hello@ploy.ai" class="olink flex items-center gap-[8px] w-[384px] text-[length:var(--font-size-2xl)] leading-[32px] tracking-[var(--font-body-letter-spacing)] text-[color:var(--ploy-background-secondary)] no-underline max-[1024px]:w-full max-[540px]:w-full max-[540px]:text-[length:var(--font-size-xl)] max-[1024px]:text-[length:var(--font-size_2xl)]" aria-label="Email hello@ploy.ai" data-el="footer-link">
            → hello@ploy.ai
          </a>
        </div>
      </div>
      <div class="flex justify-between items-center w-full">
        <div>
          <Copyright company="Ploy LLC" />
        </div>
        <a href="https://tonik.com" class="olink flex justify-between items-center w-[96px] no-underline cursor-pointer text-[color:var(--ploy-background-secondary)] max-[1024px]:w-[96px]" target="_blank" rel="noopener noreferrer" aria-label="Made by Tonik" data-el="footer-link">
          <span class="text-[length:var(--font-size-base)] leading-[var(--font-body-line-height)] tracking-[var(--font-body-letter-spacing)] text-[color:var(--ploy-background-secondary)] opacity-[0.64]">
            Made by
          </span>
          <span class="flex justify-center items-center p-[4px]">
            <div class="oem w-[20px] h-[20px] overflow-visible text-[color:var(--bg)]">
              <Fragment set:html={`<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" style="width: 20px; height: 20px; overflow: visible">
<path d="M18.5652 1.43021C17.1749 0.0395873 14.9703 -0.352767 12.3536 0.322679C9.79642 0.983225 7.13501 2.59734 4.86586 4.872C2.59672 7.1417 0.982988 9.79878 0.322601 12.3565C-0.352682 14.9689 0.0395777 17.1741 1.42987 18.5696C2.82015 19.9652 3.69902 20 5.27302 20C6.84703 20 6.80234 19.8907 7.64148 19.6772C10.1986 19.0166 12.86 17.4025 15.1292 15.1279C17.3983 12.8582 19.012 10.1961 19.6774 7.63835C20.3527 5.02597 19.9604 2.82083 18.5701 1.42524L18.5652 1.43021ZM19.1114 7.49929C18.4758 9.95771 16.9167 12.5254 14.717 14.7206C12.5174 16.9158 9.95531 18.4802 7.49748 19.116C5.09427 19.7368 3.08332 19.3991 1.84695 18.1574C0.605624 16.9158 0.267982 14.9093 0.888647 12.5055C1.52421 10.0471 3.08332 7.47942 5.28295 5.28422C7.48259 3.08903 10.0447 1.52457 12.5025 0.888861C13.287 0.685234 14.0318 0.585904 14.722 0.585904C16.1371 0.585904 17.3189 1.01302 18.153 1.8474C19.3944 3.08903 19.732 5.0955 19.1114 7.49929Z" fill="CurrentColor" />
<path d="M14.8951 6.64904L14.5078 6.24189L14.1006 5.81488L11.5535 8.23792L10.2476 4.97576L9.18008 5.40277L10.4859 8.66493H6.97055V7.19025H5.81861V14.1615H6.97055V9.81687H10.5505L9.4631 13.228L9.99935 13.3968L10.5654 13.5805L11.6726 10.08L14.8951 11.8377L15.1632 11.3412L15.4462 10.8248L12.3082 9.1118L14.8951 6.64904Z" fill="CurrentColor" />
</svg>`} />
            </div>
          </span>
        </a>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
(function(){
var el = document.currentScript.previousElementSibling;
function __init__() {
(function _w(n){var c=n.firstChild,x;while(c){x=c.nextSibling;if(c.nodeType===3){if(!c.textContent.trim())n.removeChild(c)}else if(c.nodeType===1)_w(c);c=x}})(el);
// Footer link hover animation — char-by-char color swap like GetStartedButton
var footerLinks = el.querySelectorAll('[data-el="footer-link"]');
if (typeof gsap !== 'undefined') {
  footerLinks.forEach(function(link) {
    // Find text-only child elements and split their text into char spans
    // Preserve non-text elements (SVG embeds etc.)
    var chars = [];

    // Split text into char spans — handle both direct text nodes and text child elements
    var childNodes = Array.prototype.slice.call(link.childNodes);
    childNodes.forEach(function(child) {
      if (child.nodeType === 3 && child.textContent.trim()) {
        // Direct text node — wrap chars in a single wrapper span to avoid flex gap between chars
        var text = child.textContent;
        var wrapper = document.createElement('span');
        wrapper.style.cssText = 'display:inline-flex;gap:0;align-items:center;';
        for (var i = 0; i < text.length; i++) {
          var span = document.createElement('span');
          span.textContent = text[i] === ' ' ? '\u00A0' : text[i];
          span.style.display = 'inline-block';
          wrapper.appendChild(span);
          chars.push(span);
        }
        child.parentNode.replaceChild(wrapper, child);
      } else if (child.nodeType === 1) {
        // Element node — skip SVG containers
        if (child.querySelector('svg') || child.tagName === 'SVG') return;

        var text = child.textContent.trim();
        if (!text) return;

        child.textContent = '';
        child.style.display = 'inline-flex';
        child.style.gap = '0';
        child.style.alignItems = 'center';

        for (var i = 0; i < text.length; i++) {
          var span = document.createElement('span');
          span.textContent = text[i] === ' ' ? '\u00A0' : text[i];
          span.style.display = 'inline-block';
          child.appendChild(span);
          chars.push(span);
        }
      }
    });

    if (!chars.length) return;

    // Find SVG container to animate its color too (SVG uses fill="currentColor")
    var svgEl = link.querySelector('svg');
    var svgContainer = svgEl ? svgEl.closest('[style]') || svgEl.parentNode : null;
    var originalSvgColor = svgContainer ? getComputedStyle(svgContainer).color : null;

    var originalColor = getComputedStyle(link).color;
    var hoverColors = ['#FFB8FC', '#C3DBFF', '#FFFA64', '#D1F48C'];
    var lastColor = null;

    function pickColor() {
      var available = hoverColors.filter(function(c) { return c !== lastColor; });
      var picked = available[Math.floor(Math.random() * available.length)];
      lastColor = picked;
      return picked;
    }

    var hoverTimeline = null;

    function buildTimeline(color) {
      if (hoverTimeline) hoverTimeline.kill();
      hoverTimeline = gsap.timeline({
        onComplete: function() {
          hoverTimeline.progress(0).pause();
          gsap.set(chars, { color: originalColor, scaleY: 1, rotate: 0 });
          if (svgContainer) gsap.set(svgContainer, { color: originalSvgColor });
        }
      });
      gsap.set(chars, { transformOrigin: 'bottom left' });
      hoverTimeline
        .to(chars, {
          keyframes: {
            '0%': { scaleY: 1, rotate: 0 },
            '20%': { scaleY: 0.25, rotate: 20, ease: 'power2.in' },
            '100%': { scaleY: 1, rotate: 0, ease: 'elastic.out(1,0.4)' }
          },
          duration: 0.7,
          stagger: 0.017
        })
        .to(chars, {
          keyframes: {
            '0%': { color: color },
            '40%': { color: color },
            '100%': { color: originalColor }
          },
          duration: 0.7,
          stagger: 0.017
        }, '<');

      // Animate SVG color in sync
      if (svgContainer) {
        hoverTimeline.to(svgContainer, {
          keyframes: {
            '0%': { color: color },
            '40%': { color: color },
            '100%': { color: originalSvgColor }
          },
          duration: 0.7
        }, '<');
      }
    }

    link.addEventListener('pointerenter', function() {
      buildTimeline(pickColor());
      hoverTimeline.play();
    });
  });
}

// Footer — inflate video and play on scroll into view
var video = el.querySelector('[data-el="footer-video"]');
if (!video) return;

var startScale = 0.4;
var endScale = 1.3;

video.style.transform = 'scale(' + startScale + ')';
video.style.transition = 'none';
video.pause();

function startVideo() {
  video.play();
}

if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo(video,
    { scale: startScale },
    {
      scale: endScale,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 85%',
        end: 'top 20%',
        scrub: 0.8,
        onEnter: startVideo
      }
    }
  );
} else {
  video.style.transition = 'transform 1s cubic-bezier(0.22, 1, 0.36, 1)';

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        video.style.transform = 'scale(' + endScale + ')';
        startVideo();
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  observer.observe(el);
}

}
if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', __init__); } else { __init__(); }
})();
</script>
