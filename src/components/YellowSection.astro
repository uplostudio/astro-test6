<script is:inline>
(function(){
var el = document.currentScript.previousElementSibling;
function __init__() {
(function _w(n){var c=n.firstChild,x;while(c){x=c.nextSibling;if(c.nodeType===3){if(!c.textContent.trim())n.removeChild(c)}else if(c.nodeType===1)_w(c);c=x}})(el);
// Yellow balloon — slow spin + subtle random float
var balloon = el.querySelector('[data-el="yellow-balloon"]');
if (!balloon) return;

// Continuous slow rotation
var angle = 0;
var rotSpeed = 0.15; // degrees per frame

// Subtle random float offsets
var floatX = 0;
var floatY = 0;
var targetX = 0;
var targetY = 0;
var floatRange = 6; // max px drift
var ease = 0.02;

function pickNewTarget() {
  targetX = (Math.random() - 0.5) * 2 * floatRange;
  targetY = (Math.random() - 0.5) * 2 * floatRange;
}

pickNewTarget();
var retargetInterval = setInterval(pickNewTarget, 2000 + Math.random() * 1500);

function animate() {
  angle += rotSpeed;
  if (angle >= 360) angle -= 360;

  // Ease toward target
  floatX += (targetX - floatX) * ease;
  floatY += (targetY - floatY) * ease;

  balloon.style.transform = 'translate(' + floatX.toFixed(2) + 'px, ' + floatY.toFixed(2) + 'px) rotate(' + angle.toFixed(2) + 'deg)';
  requestAnimationFrame(animate);
}

requestAnimationFrame(animate);

}
if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', __init__); } else { __init__(); }
})();
</script>
