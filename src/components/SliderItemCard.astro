---
interface Props {
  Title?: string;
  text2?: string;
  class?: string;
}

const {
  Title = "SEO<br>Audit Blueprint",
  text2 = "Full-spectrum audit across 6 dimensions. Technical, content, keywords, backlinks, competitive landscape, and AI search visibility.",
  class: className = "",
} = Astro.props;
---
<div class:list={["w-full flex flex-col items-start rounded-[8px] overflow-hidden max-w-[384px] min-w-[260px] relative h-full", className]}>
  <div class="flex flex-col items-start gap-[8px] p-[24px_24px_112px_48px] bg-[var(--ploy-brand-blue-light)] w-full flex-1 h-full max-[540px]:p-[20px_20px_80px_36px] max-[1024px]:p-[22px_22px_88px_40px]">
    <div class="flex flex-col items-start gap-[24px] w-full max-[1024px]:gap-[21px] max-[540px]:gap-[19px]">
      <div class="oem h-[24px] w-[65px] overflow-visible">
        <Fragment set:html={`<svg width="65" height="24" viewBox="0 0 65 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="height: 24px; width: 65px; overflow: visible">
<path d="M12.8046 4.90723C24.2214 4.73166 24.2187 19.2689 12.8046 19.0928C6.05132 18.9304 5.26692 15.2347 5.26175 15.21H5.02791L5.48491 24H0V5.33301H5.48491C5.48002 5.3759 5.01708 8.79697 5.02015 8.79004H5.26175C5.26015 8.78125 6.04293 5.0646 12.8046 4.90723Z" fill="#212121" />
<path d="M54.9888 12.8008L58.9019 5.33301H65L55.1751 24H49.1041L52.0596 18.374L44.8709 5.33301H51.0486L54.9888 12.8008Z" fill="#212121" />
<path d="M37.6376 4.90723C42.7763 4.90724 46.1836 7.73329 46.1836 12C46.1836 16.2667 42.7763 19.0928 37.6376 19.0928C32.4988 19.0928 29.0905 16.2666 29.0905 12C29.0905 7.73347 32.4988 4.90723 37.6376 4.90723Z" fill="#212121" />
<path d="M27.9097 18.667H22.5315V0H27.9097V18.667Z" fill="#212121" />
</svg>`} />
      </div>
      <p class="w-full text-[length:var(--font-size-3xl)] font-[number:var(--font-body-bold-weight)] leading-[125%] tracking-[-0.04em] text-[color:var(--ploy-text-primary)] max-[1024px]:text-[length:var(--font-size_3xl)] max-[540px]:text-[length:var(--font-size_3xl)]">
        {Title}
      </p>
    </div>
  </div>
  <div class="flex justify-center items-center gap-[8px] p-[24px_24px_24px_48px] bg-[var(--ploy-background-secondary)] w-full max-[540px]:p-[20px_20px_20px_36px] max-[1024px]:p-[22px_22px_22px_40px]">
    <p class="max-w-[312px] w-full text-[length:var(--font-size-base)] leading-[var(--font-body-line-height)] tracking-[var(--font-body-letter-spacing)] text-[color:var(--ploy-text-primary)] opacity-[0.64]">
      {text2}
    </p>
  </div>
  <div class="absolute h-full w-[1px] bg-[color:var(--ploy-border-subtle)] left-[24px] top-[0px]" />
</div>

<script define:vars={{ Title, text2 }}>
(function(){
var el = document.currentScript.previousElementSibling;
function __init__() {
(function _w(n){var c=n.firstChild,x;while(c){x=c.nextSibling;if(c.nodeType===3){if(!c.textContent.trim())n.removeChild(c)}else if(c.nodeType===1)_w(c);c=x}})(el);
// SliderItemCard — 3D book tilt on mouse hover
var card = el;

card.style.perspective = '800px';
card.style.transformStyle = 'preserve-3d';

var inner = card.children[0];
if (!inner) return;

// Apply 3D styles to root
card.style.transition = 'transform 0.3s ease-out, box-shadow 0.3s ease-out';
card.style.willChange = 'transform';

var maxRotX = 8;  // max tilt degrees vertical
var maxRotY = 12; // max tilt degrees horizontal

function handleMove(e) {
  var rect = card.getBoundingClientRect();
  var x = (e.clientX - rect.left) / rect.width;
  var y = (e.clientY - rect.top) / rect.height;

  // Map 0-1 to -1 to 1
  var rotY = (x - 0.5) * 2 * maxRotY;
  var rotX = -(y - 0.5) * 2 * maxRotX;

  card.style.transform = 'rotateX(' + rotX.toFixed(2) + 'deg) rotateY(' + rotY.toFixed(2) + 'deg) scale3d(1.02, 1.02, 1.02)';
  card.style.boxShadow = '0 ' + (10 + rotX).toFixed(0) + 'px ' + (30 + Math.abs(rotY)).toFixed(0) + 'px rgba(0,0,0,0.12)';
}

function handleLeave() {
  card.style.transform = 'rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
  card.style.boxShadow = '';
}

card.addEventListener('mousemove', handleMove);
card.addEventListener('mouseleave', handleLeave);

}
if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', __init__); } else { __init__(); }
})();
</script>
